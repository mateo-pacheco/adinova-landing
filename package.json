{
  "name": "adinova",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "npm run build && wrangler pages deploy dist/ADINOVA/browser --project-name=adinova",
    "deploy:dev": "npm run build && wrangler pages deploy dist/ADINOVA/browser --project-name=adinova --env=development",
    "sitemap:ping": "node scripts/sitemap-ping.mjs",
    "sitemap:submit": "node -e \"const u='https://search.google.com/search-console/sitemaps?resource_id=https://adinovaestudio.com/';console.log('Abre este enlace en tu navegador:');console.log(u);const{execSync:e=require('child_process').execSync}=require('child_process');try{e('start '+u)}catch{}\"",
    "serve:ssr:ADINOVA": "node dist/ADINOVA/server/server.mjs",
    "optimize:images": "node scripts/optimize-images.mjs"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/ssr": "^21.2.13",
    "@emailjs/browser": "^4.4.1",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.184.0",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "three": "^0.184.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
